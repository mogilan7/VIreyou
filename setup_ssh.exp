#!/usr/bin/expect -f
set timeout 10
set host "92.63.99.117"
set user "root"
set password "MedMail1981"
set pubkey "ssh-rsa  mogilevandrei@MacBook-Pro-Andrey-2.local"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect {
    "password:" {
        send "$password\r"
    }
}
expect {
    "#" {
        send "mkdir -p ~/.ssh && chmod 700 ~/.ssh\r"
        send "echo '$pubkey' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\r"
        send "echo 'SSH_SETUP_OK'\r"
        send "exit\r"
    }
}
expect eof
